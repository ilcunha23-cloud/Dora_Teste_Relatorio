# PARTE D) ABUNDÂNCIA RELATIVA POR ESPÉCIE
# Barras empilhadas por fitofisionomia
# ============================================================

abund_sf <- dat2 %>%
  count(Especie, Fitofisionomia, name = "n")

tot_species <- abund_sf %>%
  group_by(Especie) %>%
  summarise(n_total = sum(n), .groups = "drop") %>%
  arrange(desc(n_total))

grand_total <- sum(tot_species$n_total)
if (grand_total <= 0) stop("Abundância total igual a zero.")

plot_df <- abund_sf %>%
  left_join(tot_species, by = "Especie") %>%
  mutate(
    abundancia_relativa_segmento = n / grand_total,
    Especie = factor(Especie, levels = tot_species$Especie),
    Fitofisionomia = factor(Fitofisionomia, levels = grupos_fitofisionomia)
  )

write_csv(plot_df,
          file.path(output_dir, "Abundancia_Relativa_por_Especie_segmentada_por_Fitofisionomia.csv"))

p_hist <- ggplot(plot_df, aes(x = Especie, y = abundancia_relativa_segmento, fill = Fitofisionomia)) +
  geom_col(width = 0.85) +
  scale_y_continuous(labels = percent_format(accuracy = 0.1)) +
  labs(
    title = "Abundância relativa geral por espécie",
    subtitle = "Barras segmentadas por fitofisionomia",
    x = "Espécies",
    y = "Abundância relativa",
    fill = "Fitofisionomia"
  ) +
  theme_bw() +
  theme(
    axis.text.x = element_text(angle = 60, hjust = 1, vjust = 1),
    plot.title = element_text(hjust = 0.5),
    plot.subtitle = element_text(hjust = 0.5)
  )

