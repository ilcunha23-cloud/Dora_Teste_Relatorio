# PARTE B) ÍNDICES DE BIODIVERSIDADE
# Shannon, Simpson, riqueza observada e abundância total
# ============================================================

abund_form <- dat2 %>%
  count(Fitofisionomia, Especie, name = "n") %>%
  pivot_wider(names_from = Especie, values_from = n, values_fill = 0) %>%
  arrange(Fitofisionomia)

abund_geral <- dat2 %>%
  count(Especie, name = "n") %>%
  pivot_wider(names_from = Especie, values_from = n, values_fill = 0)

calc_div <- function(mat, grupo) {
  tibble(
    Grupo = grupo,
    Abundancia_total = rowSums(mat),
    Riqueza_observada = specnumber(mat),
    Shannon = diversity(mat, index = "shannon"),
    Simpson_1_D = diversity(mat, index = "simpson"),
    Inverso_Simpson = diversity(mat, index = "invsimpson")
  )
}

div_geral <- calc_div(abund_geral, "Área total")

div_form <- calc_div(abund_form %>% select(-Fitofisionomia), abund_form$Fitofisionomia)

indices_biodiversidade <- bind_rows(div_geral, div_form) %>%
  mutate(across(where(is.numeric), ~ round(.x, 4)))

