# Para curva Mao Tau, o método mais adequado no vegan é "exact".
# Se quiser a curva por randomizações, troque para "random".
metodo_curva <- "exact"
n_perm <- 1000

make_incidence_day <- function(df, all_dates) {
  inc <- df %>%
    distinct(Data, Especie) %>%
    mutate(pres = 1) %>%
    pivot_wider(names_from = Especie, values_from = pres, values_fill = 0)

  base_days <- tibble(Data = all_dates)

  inc_full <- base_days %>%
    left_join(inc, by = "Data") %>%
    arrange(Data)

  inc_full[is.na(inc_full)] <- 0

  out <- inc_full %>% select(-Data) %>% as.data.frame()

  # Se só houver uma espécie, garantir que continue como data.frame
  if (ncol(out) == 0) stop("Não há espécies válidas para montar a matriz de incidência.")
  return(out)
}

calc_specaccum <- function(X, metodo = "exact", n_perm = 1000) {
  if (metodo == "random") {
    sac <- specaccum(X, method = "random", permutations = n_perm)
  } else {
    sac <- specaccum(X, method = "exact")
  }

  tibble(
    dia = seq_along(sac$sites),
    riqueza_media = as.numeric(sac$richness),
    sd = as.numeric(sac$sd),
    riqueza_min = pmax(0, riqueza_media - sd),
    riqueza_max = riqueza_media + sd
  )
}

grupos_fitofisionomia <- sort(unique(dat2$Fitofisionomia))
grupos <- c("Área total", grupos_fitofisionomia)

lista_curvas <- list()

for (g in grupos) {
  df_g <- if (g == "Área total") dat2 else dat2 %>% filter(Fitofisionomia == g)

  X <- make_incidence_day(df_g, sampling_dates)

  lista_curvas[[g]] <- calc_specaccum(X, metodo = metodo_curva, n_perm = n_perm) %>%
    mutate(
      Grupo = g,
      Metodo = ifelse(metodo_curva == "exact", "Mao Tau/exact", "Random")
    )
}

curvas <- bind_rows(lista_curvas)

