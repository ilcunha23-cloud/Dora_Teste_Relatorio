# ============================================================
# PARTE C) SIMILARIDADE ENTRE FITOFISIONOMIAS
# Jaccard: presença/ausência
# Bray-Curtis: abundância
# ============================================================

if (nrow(abund_form) >= 2) {
  pa_form <- abund_form
  pa_form[, -1] <- (pa_form[, -1] > 0) * 1

  dist_jacc <- vegdist(pa_form %>% select(-Fitofisionomia), method = "jaccard", binary = TRUE)
  sim_jacc <- 1 - as.matrix(dist_jacc)
  rownames(sim_jacc) <- pa_form$Fitofisionomia
  colnames(sim_jacc) <- pa_form$Fitofisionomia

  dist_bray <- vegdist(abund_form %>% select(-Fitofisionomia), method = "bray")
  sim_bray <- 1 - as.matrix(dist_bray)
  rownames(sim_bray) <- abund_form$Fitofisionomia
  colnames(sim_bray) <- abund_form$Fitofisionomia

  write.csv(round(sim_jacc, 6), file.path(output_dir, "Similaridade_Jaccard_Fitofisionomias.csv"))
  write.csv(round(sim_bray, 6), file.path(output_dir, "Similaridade_BrayCurtis_Fitofisionomias.csv"))

  sim_jacc_df <- as.data.frame(round(sim_jacc, 4))
  sim_jacc_df <- cbind(Fitofisionomia = rownames(sim_jacc_df), sim_jacc_df)

  png(filename = file.path(output_dir, "Tabela_Similaridade_Jaccard.png"),
      width = 2200, height = 1200, res = 300)
  grid.newpage()
  grid.table(sim_jacc_df)
  dev.off()

  sim_bray_df <- as.data.frame(round(sim_bray, 4))
  sim_bray_df <- cbind(Fitofisionomia = rownames(sim_bray_df), sim_bray_df)

  png(filename = file.path(output_dir, "Tabela_Similaridade_BrayCurtis.png"),
      width = 2200, height = 1200, res = 300)
  grid.newpage()
  grid.table(sim_bray_df)
  dev.off()
} else {
  warning("Há menos de duas fitofisionomias. Similaridade não foi calculada.")
}

